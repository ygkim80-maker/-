generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String
  shipperId String?
  createdAt DateTime @default(now())
  pickTasks PickTask[]
  laborLogs ProductivityLog[]
}

model Warehouse {
  id        String  @id @default(cuid())
  name      String
  address   String
  zones     Zone[]
}

model Zone {
  id          String     @id @default(cuid())
  warehouseId String
  warehouse   Warehouse  @relation(fields: [warehouseId], references: [id])
  name        String
  code        String
  type        String
  locations   Location[]
}

model Location {
  id           String      @id @default(cuid())
  zoneId       String
  zone         Zone        @relation(fields: [zoneId], references: [id])
  code         String      @unique
  aisle        String
  bay          String
  level        String
  position     String
  locationType String
  capacity     Int
  isActive     Boolean     @default(true)
  inventory    Inventory[]
  pickTasks    PickTask[]
  cycleCounts  CycleCount[]
}

model CycleCount {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])
  itemId      String?
  systemQty   Int
  countedQty  Int?
  status      String
  countedBy   String?
  countedAt   DateTime?
  createdAt   DateTime @default(now())
}

model Supplier {
  id            String          @id @default(cuid())
  name          String
  code          String          @unique
  contact       String?
  purchaseOrders PurchaseOrder[]
}

model Item {
  id           String      @id @default(cuid())
  sku          String      @unique
  barcode      String?
  name         String
  category     String
  uom          String
  weight       Float?
  length       Float?
  width        Float?
  height       Float?
  reorderPoint Int         @default(0)
  supplierId   String?
  shipperId    String?
  shipper      Shipper?    @relation(fields: [shipperId], references: [id])
  inventory    Inventory[]
  poLines      POLine[]
  soLines      SOLine[]
  pickTasks    PickTask[]
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  poNumber     String    @unique
  supplierId   String
  supplier     Supplier  @relation(fields: [supplierId], references: [id])
  shipperId    String?
  shipper      Shipper?  @relation(fields: [shipperId], references: [id])
  status       String
  expectedDate DateTime?
  createdAt    DateTime  @default(now())
  lines        POLine[]
  receipts     Receipt[]
  dockAppointment DockAppointment?
}

model POLine {
  id          String        @id @default(cuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id])
  itemId      String
  item        Item          @relation(fields: [itemId], references: [id])
  orderedQty  Int
  receivedQty Int           @default(0)
}

model Receipt {
  id          String        @id @default(cuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id])
  receivedBy  String
  receivedAt  DateTime      @default(now())
  lines       ReceiptLine[]
}

model ReceiptLine {
  id         String   @id @default(cuid())
  receiptId  String
  receipt    Receipt  @relation(fields: [receiptId], references: [id])
  itemId     String
  qty        Int
  lot        String?
  serialNum  String?
  expiryDate DateTime?
  condition  String
}

model Inventory {
  id         String    @id @default(cuid())
  locationId String
  location   Location  @relation(fields: [locationId], references: [id])
  itemId     String
  item       Item      @relation(fields: [itemId], references: [id])
  shipperId  String?
  shipper    Shipper?  @relation(fields: [shipperId], references: [id])
  qty        Int
  lot        String?
  expiryDate DateTime?
  updatedAt  DateTime  @updatedAt
}

model Shipper {
  id           String          @id @default(cuid())
  name         String
  code         String          @unique
  contactEmail String?
  items        Item[]
  inventory    Inventory[]
  salesOrders  SalesOrder[]
  purchaseOrders PurchaseOrder[]
}

model Channel {
  id         String       @id @default(cuid())
  name       String
  code       String       @unique
  type       String
  isActive   Boolean      @default(true)
  orders     SalesOrder[]
}

model SalesOrder {
  id              String     @id @default(cuid())
  orderNumber     String     @unique
  channelId       String
  channel         Channel    @relation(fields: [channelId], references: [id])
  shipperId       String?
  shipper         Shipper?   @relation(fields: [shipperId], references: [id])
  customerName    String
  customerAddr    String
  customerPhone   String?
  status          String
  slaType         String
  requestedShipDate DateTime?
  createdAt       DateTime   @default(now())
  lines           SOLine[]
  wave            Wave?      @relation(fields: [waveId], references: [id])
  waveId          String?
  shipment        Shipment?
  pickTasks       PickTask[]
}

model SOLine {
  id         String     @id @default(cuid())
  soId       String
  so         SalesOrder @relation(fields: [soId], references: [id])
  itemId     String
  item       Item       @relation(fields: [itemId], references: [id])
  orderedQty Int
  pickedQty  Int        @default(0)
  price      Float      @default(0)
}

model Wave {
  id          String       @id @default(cuid())
  waveNumber  String       @unique
  status      String
  waveType    String
  plannedAt   DateTime     @default(now())
  releasedAt  DateTime?
  completedAt DateTime?
  orders      SalesOrder[]
  pickTasks   PickTask[]
}

model PickTask {
  id          String     @id @default(cuid())
  waveId      String?
  wave        Wave?      @relation(fields: [waveId], references: [id])
  soId        String
  so          SalesOrder @relation(fields: [soId], references: [id])
  locationId  String
  location    Location   @relation(fields: [locationId], references: [id])
  itemId      String
  item        Item       @relation(fields: [itemId], references: [id])
  qty         Int
  pickedQty   Int        @default(0)
  status      String
  assignedTo  String?
  worker      User?      @relation(fields: [assignedTo], references: [id])
  startedAt   DateTime?
  completedAt DateTime?
}

model Carrier {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  apiUrl    String?
  isActive  Boolean    @default(true)
  shipments Shipment[]
}

model Shipment {
  id             String     @id @default(cuid())
  soId           String     @unique
  so             SalesOrder @relation(fields: [soId], references: [id])
  carrierId      String
  carrier        Carrier    @relation(fields: [carrierId], references: [id])
  trackingNumber String?
  status         String
  shippedAt      DateTime?
  deliveredAt    DateTime?
  weight         Float?
  shippingFee    Float?
}

model DockDoor {
  id           String            @id @default(cuid())
  warehouseId  String
  doorNumber   String
  type         String
  isActive     Boolean           @default(true)
  appointments DockAppointment[]
}

model DockAppointment {
  id            String         @id @default(cuid())
  dockDoorId    String
  dockDoor      DockDoor       @relation(fields: [dockDoorId], references: [id])
  poId          String?        @unique
  po            PurchaseOrder? @relation(fields: [poId], references: [id])
  type          String
  vehiclePlate  String?
  driverName    String?
  scheduledAt   DateTime
  arrivedAt     DateTime?
  departedAt    DateTime?
  status        String
}

model WorkerSchedule {
  id        String   @id @default(cuid())
  workerId  String
  date      DateTime
  shift     String
  zone      String?
  status    String
  checkedIn DateTime?
  checkedOut DateTime?
}

model ProductivityLog {
  id        String   @id @default(cuid())
  workerId  String
  worker    User     @relation(fields: [workerId], references: [id])
  date      DateTime @default(now())
  taskType  String
  quantity  Int
  duration  Int
}

model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())
}

model Alert {
  id        String   @id @default(cuid())
  type      String
  severity  String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
