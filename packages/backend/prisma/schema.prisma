generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String
  phone        String?
  role         String        // RIDER | COMPANY
  profileImage String?
  bio          String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // RIDER fields
  vehicleType  String?       // WALK | BIKE | MOTORCYCLE | CAR
  experience   Int?          // months
  regions      String?       // comma-separated region codes
  licenseVerified Boolean    @default(false)

  // COMPANY fields
  companyName  String?
  businessNumber String?
  companyAddress String?

  jobPostings  JobPosting[]
  applications Application[]
  reviewsGiven Review[]      @relation("ReviewAuthor")
  reviewsReceived Review[]   @relation("ReviewTarget")
}

model JobPosting {
  id            String        @id @default(cuid())
  companyId     String
  company       User          @relation(fields: [companyId], references: [id])
  title         String
  description   String
  cardType      String        // CREDIT | DEBIT | PREPAID | MEMBERSHIP | OTHER
  region        String
  regionDetail  String?
  dailyCount    Int           // expected daily delivery count
  payType       String        // PER_CARD | DAILY | MONTHLY
  payAmount     Int
  startDate     DateTime
  endDate       DateTime?
  workDays      String?       // e.g. "MON,TUE,WED,THU,FRI"
  workStartTime String?       // e.g. "09:00"
  workEndTime   String?       // e.g. "18:00"
  vehicleType   String?       // required vehicle type
  status        String        @default("OPEN") // OPEN | CLOSED | PAUSED
  isUrgent      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  applications  Application[]
}

model Application {
  id          String     @id @default(cuid())
  jobId       String
  job         JobPosting @relation(fields: [jobId], references: [id])
  riderId     String
  rider       User       @relation(fields: [riderId], references: [id])
  message     String?
  status      String     @default("PENDING") // PENDING | ACCEPTED | REJECTED | CANCELLED
  appliedAt   DateTime   @default(now())
  respondedAt DateTime?

  @@unique([jobId, riderId])
}

model Review {
  id         String   @id @default(cuid())
  authorId   String
  author     User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetId   String
  target     User     @relation("ReviewTarget", fields: [targetId], references: [id])
  jobId      String?
  rating     Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // APPLICATION | ACCEPTED | REJECTED | NEW_JOB
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
